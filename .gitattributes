# ===== 强制 LF 行尾 =====
# 原因：Windows 上 Git 默认 autocrlf=true，会把 LF 转 CRLF，
#       会导致 shell 脚本（start.sh）在 Linux/Mac 上跑不了，
#       也会让 git diff 看到满屏换行符噪音。
# 解决：仓库内用 .gitattributes 强制所有文本文件 LF，覆盖全局配置。
* text=auto eol=lf

# ===== 显式声明（防御性，防止 text=auto 误判）=====
# 文档
*.md        text eol=lf
*.txt       text eol=lf

# 后端
*.py        text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf

# 前端 / Android
*.kt        text eol=lf
*.kts       text eol=lf
*.java      text eol=lf
*.gradle    text eol=lf
*.xml       text eol=lf

# 配置 / 数据
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.env       text eol=lf
*.env.example text eol=lf

# Shell 脚本（必须 LF，否则 Linux/Mac 上无法执行）
*.sh        text eol=lf
*.bash      text eol=lf

# Windows 脚本（必须 CRLF）
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Git 相关
.gitignore  text eol=lf
.gitattributes text eol=lf

